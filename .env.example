# Server
PORT=3001
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Session (required in production — min 32 characters)
SESSION_SECRET=change-me-to-a-long-random-string

# Report mode (keep true for first Render QA deploy)
USE_MOCK_REPORT=true

# Dev-only: enables POST /api/auth/dev-session for local/smoke testing (never true in production or Render)
ALLOW_DEV_SESSION=false

# Pegasus iframe auth
PEGASUS_API_URL=https://api.pegasusgateway.com
PEGASUS_AUTH_MODE=iframe
PEGASUS_ALLOWED_PARENT_ORIGIN=

# Twilio (optional until Slice 3)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Hosted QA only: enable masked /api/report/scope diagnostics (default false)
ENABLE_SCOPE_DIAGNOSTICS=false
